# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/settings

# Encryption key (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your_32_byte_hex_key_here

# Vercel KV (get from Vercel dashboard → Storage → KV)
# For local dev without KV, file-based storage is used automatically
KV_REST_API_URL=https://xxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxx
KV_REST_API_READ_ONLY_TOKEN=xxxx

# Stripe billing (Starter plan checkout)
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
# Price ID under product prod_Uj7iZU8V4jL0sk (Stripe Dashboard > Products) — not the Product ID itself
STRIPE_STARTER_PRICE_ID=price_xxxx
